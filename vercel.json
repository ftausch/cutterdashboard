{
  "regions": ["fra1"],
  "functions": {
    "src/app/api/**": {
      "memory": 256
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-views",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/generate-alerts",
      "schedule": "0 6 * * *"
    }
  ]
}
